# ================================================
# ShellMate — Environment Variables
# Copy this file to .env.local and fill in values
# Add all these to Railway as environment variables
# ================================================

# --- SUPABASE (from supabase.com > your project > settings > API) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- ANTHROPIC (from console.anthropic.com > API Keys) ---
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- STRIPE (from dashboard.stripe.com > Developers > API Keys) ---
STRIPE_SECRET_KEY=sk_live_your-key-here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here

# Stripe Price IDs (create these in Stripe Dashboard > Products)
# Create 3 products: Terminal Pro, Companion Pro, Bundle
STRIPE_PRICE_TERMINAL=price_your-terminal-price-id
STRIPE_PRICE_COMPANION=price_your-companion-price-id
STRIPE_PRICE_BUNDLE=price_your-bundle-price-id

# --- APP ---
NEXT_PUBLIC_APP_URL=https://your-railway-domain.up.railway.app
